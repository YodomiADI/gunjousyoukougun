[sub_resource type="Resource" id="Resource_8x785"]
script = ExtResource("1_phd66")
text = "死期が見えるようになった。
西暦何年何月何日。
時間までは書いていない。
でもその日に必ず死は訪れる。"
background = ExtResource("1_4mfdp")
bgm = ExtResource("2_l5nuy")
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_l5nuy"]
script = ExtResource("1_phd66")
text = "いつから見えるようになったかは覚えていない。
最初はただ数字が頭上に浮かんでいるだけだと思っていた。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_bs7l3"]
script = ExtResource("1_phd66")
text = "俺は不謹慎にもその数字が当日と一致する日を待ちわびてしまった。
というのも、毎朝元気な挨拶をしてくれる近所のおじいさんがもうすぐでその数字が近づいていたのだ。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_4gooj"]
script = ExtResource("1_phd66")
text = "当日の朝、おじいさんの挨拶はなかった。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_igjyp"]
script = ExtResource("1_phd66")
text = "その日の夕方、パトカーが物々しく赤いランプを音を立てずに回っていたのが脳裏にこびりついている。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_l0lse"]
script = ExtResource("1_phd66")
text = "原因は夜中の心筋梗塞。
発見に至ったのはおじいさんと面識のある町内会のおばさん達。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_fmsum"]
script = ExtResource("1_phd66")
text = "毎朝のご近所づきあいに決められた時間に世間話しに来なかったため確認しに行ったところ、違和感を覚え警察を呼びそのまま確認に至る。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_0xtgi"]
script = ExtResource("1_phd66")
text = "そんな詳しい話を晩ご飯の最中に聞かされ、食べ物が喉を通りにくかったことを覚えている。だが、もっと喉を通らなくなったことがある。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_8kqiv"]
script = ExtResource("1_phd66")
text = "近所の野良猫だ。"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="CompressedTexture2D" id="CompressedTexture2D_8x785"]
load_path = "res://.godot/imported/猫立ち絵.png-f72c252f9d0963fec3f9e073a7d3fbee.ctex"

[sub_resource type="Resource" id="Resource_1rey7"]
script = ExtResource("1_phd66")
char_id = 4
text = "この猫も同じく頭上の数字が近づいていた。
まるで自分の死期を眺めるように中空をじっと眺めていた猫はとても年老いていた。"
character_sprite = SubResource("CompressedTexture2D_8x785")
background = ExtResource("4_bs7l3")
require_hover_tutorial = true
target_char_id = "Cat"
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_fh20x"]
script = ExtResource("1_phd66")
char_id = 4
text = "俺はその後ろを一日中追いかけた。"
character_sprite = ExtResource("5_fh20x")
timer_offset = Vector2(0, 10)
metadata/_custom_type_script = "uid://cl3bhx8qa8d5x"

[sub_resource type="Resource" id="Resource_gyt3u"]
script = ExtResource("1_phd66")
char_id = 4
text = "花瓶が落ちてきそうだ。"
character_sprite = ExtResource("5_fh20x")
target_char_id = "Cat"
choices = Array[String](["猫を放置する", "花瓶から守る"])
